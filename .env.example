# Google Sheets Configuration (Optional)
# ======================================
# El dashboard ya está configurado con el spreadsheet de Granel NATU.
# Solo necesitas estas variables si quieres usar un spreadsheet diferente.

# ID del Google Sheet (se encuentra en la URL del sheet)
# Ejemplo: https://docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
# VITE_GOOGLE_SPREADSHEET_ID=tu_spreadsheet_id

# GID de la hoja (se encuentra en la URL después de gid=)
# Por defecto es 0 (primera hoja)
# VITE_SHEET_GID=0

# Google Sheets API v4 - necesaria para detectar nuevas hojas automáticamente
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_API_KEY=tu_api_key_aqui

# ID del spreadsheet de Gastos de Transporte
VITE_TRANSPORT_SPREADSHEET_ID=tu_spreadsheet_id_aqui
